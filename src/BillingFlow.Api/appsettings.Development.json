{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Exceptions", "Serilog.Enrichers.Environment", "Serilog.Formatting.Compact" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithExceptionDetails",
      "WithEnvironmentName",
      "WithMachineName"
    ],
    "Properties": {
      "Application": "BillingFlow.Api"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "RateLimiting": {
    "GlobalPermitLimit": 100,
    "GlobalWindowMinutes": 1,
    "LoginPermitLimit": 5,
    "LoginWindowMinutes": 1,
    "PasswordResetPermitLimit": 3,
    "PasswordResetWindowMinutes": 15,
    "EmailVerificationPermitLimit": 5,
    "EmailVerificationWindowMinutes": 15
  },
  "ReverseProxy": {
    "ForwardLimit": 1,
    "TrustedNetworks": [
      {
        "Ip": "172.21.0.0",
        "Prefix": 16
      }
    ]
  }
}