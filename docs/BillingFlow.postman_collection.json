    {
      "name": "8. Real-Time (SignalR)",
      "item": [
        {
          "name": "1. Negotiate Connection",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/hubs/balance/negotiate?negotiateVersion=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hubs",
                "balance",
                "negotiate"
              ],
              "query": [
                {
                  "key": "negotiateVersion",
                  "value": "1"
                }
              ]
            },
            "description": "This request uses standard HTTP to check if the server is ready to establish a SignalR connection."
          }
        },
        {
          "name": "2. Connect to Hub (Instructions)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{wsUrl}}/hubs/balance?access_token={{authToken}}",
              "host": [
                "{{wsUrl}}"
              ],
              "path": [
                "hubs",
                "balance"
              ],
              "query": [
                {
                  "key": "access_token",
                  "value": "{{authToken}}"
                }
              ]
            },
            "description": "NOTE: Postman cannot open a WebSocket connection from a standard HTTP tab.\n\nSTEP 1: COPY THIS URL:\nws://localhost/hubs/balance?access_token={{authToken}}\n\nSTEP 2: Open a new 'WebSocket Request' tab in Postman, paste the URL, and click 'Connect'.\n\nSTEP 3: IMMEDIATELY (within 15 seconds) paste the handshake message into the 'Message' box and click 'Send'."
          }
        }
      ]
    }
  ],
