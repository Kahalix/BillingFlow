# File: .env.example
# ==============================================================================
# BillingFlow Environment Variables Template
#
# INSTRUCTIONS:
# 1. Copy this file and rename it to `.env`
# 2. Replace the placeholder values with your actual local/test credentials.
# 3. NEVER commit the `.env` file to version control.
# ==============================================================================

# Application Environment
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development

# Database
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE
DB_NAME=BillingFlowDb

# Redis (SignalR Backplane for scalable WebSockets)
REDIS_CONNECTION=redis:6379,abortConnect=false

# Authentication (JWT)
# Use a strong random string (at least 64 characters) for local development
JWT_SECRET=your_super_secret_jwt_key_that_must_be_at_least_64_characters_long
JWT_ISSUER=BillingFlow
JWT_AUDIENCE=BillingFlowUsers

# Stripe Integration
# Get these from your Stripe Developer Dashboard -> API Keys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
# Run `stripe listen` in the Stripe CLI to get your local webhook secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET