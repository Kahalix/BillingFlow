# File: .env.example
# ==============================================================================
# BillingFlow Environment Variables Template
#
# INSTRUCTIONS:
# 1. Copy this file and rename it to `.env`
# 2. Replace the placeholder values with your actual local/test credentials.
# 3. NEVER commit the `.env` file to version control.
# ==============================================================================

# Application Environment
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development

# Database
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE
DB_NAME=BillingFlowDb

# Redis (SignalR Backplane for scalable WebSockets)
REDIS_CONNECTION=redis:6379,abortConnect=false

# Authentication (JWT)
# Use a strong random string (at least 64 characters) for local development
JWT_SECRET=your_super_secret_jwt_key_that_must_be_at_least_64_characters_long
JWT_ISSUER=BillingFlow
JWT_AUDIENCE=BillingFlowUsers

# Stripe Integration
# Get these from your Stripe Developer Dashboard -> API Keys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
# Run `stripe listen` in the Stripe CLI to get your local webhook secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# ==============================================================================
# RATE LIMITING
# Defines limits to protect against brute-force, DDoS, and SMTP spam.
# ==============================================================================

# .NET Internal Limits (Application Layer - evaluated per user ID or IP)
# Global limit for standard API endpoints
RATE_LIMIT_GLOBAL_PERMIT_LIMIT=100
RATE_LIMIT_GLOBAL_WINDOW_MINUTES=1

# Auth policies (evaluted strictly by IP to protect cloud infrastructure)
RATE_LIMIT_LOGIN_PERMIT_LIMIT=5
RATE_LIMIT_LOGIN_WINDOW_MINUTES=1

RATE_LIMIT_PASSWORD_RESET_PERMIT_LIMIT=3
RATE_LIMIT_PASSWORD_RESET_WINDOW_MINUTES=15

RATE_LIMIT_EMAIL_VERIFICATION_PERMIT_LIMIT=5
RATE_LIMIT_EMAIL_VERIFICATION_WINDOW_MINUTES=15

# NGINX Edge Limits (Gateway Layer)
# Global API throttle (e.g., 10 requests per second per IP)
NGINX_API_RATE=10r/s
# Stricter identity throttle (e.g., 2 requests per second per IP)
NGINX_AUTH_RATE=2r/s